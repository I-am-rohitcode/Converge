<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_call_screen"
    tools:context=".VideoCallActivity">

    <FrameLayout
        android:id="@+id/localPreview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#2A2438"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/call_preview_local"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/white_70" />
    </FrameLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#55000000"
        app:layout_constraintBottom_toBottomOf="@id/localPreview"
        app:layout_constraintEnd_toEndOf="@id/localPreview"
        app:layout_constraintStart_toStartOf="@id/localPreview"
        app:layout_constraintTop_toTopOf="@id/localPreview" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/remoteCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="72dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="200dp"
        app:cardBackgroundColor="@color/primary_variant"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/surface_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_videocam_24"
                app:tint="@color/on_primary" />

            <TextView
                android:id="@+id/remoteHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/call_preview_remote"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/white_70" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/pipLocal"
        android:layout_width="112dp"
        android:layout_height="148dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="#1E1B2A"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/primary"
        app:strokeWidth="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/call_you"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="@color/on_primary" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/peerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"
        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
        android:textColor="@color/on_primary"
        app:layout_constraintBottom_toTopOf="@id/callStatus"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="Aarav Patel" />

    <TextView
        android:id="@+id/callStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="12dp"
        android:text="@string/call_status_calling"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="@color/white_70"
        app:layout_constraintBottom_toTopOf="@id/callTimer"
        app:layout_constraintStart_toStartOf="parent" />

    <Chronometer
        android:id="@+id/callTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="20dp"
        android:format="%s"
        android:textColor="@color/on_primary"
        android:textSize="18sp"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@id/controlsRow"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/controlsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFlip"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="@string/call_flip_camera"
            app:backgroundTint="@color/surface_muted"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/on_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMute"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:contentDescription="@string/call_mute"
            app:backgroundTint="@color/surface_muted"
            app:icon="@android:drawable/ic_btn_speak_now"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/on_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVideoToggle"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:contentDescription="@string/call_video_off"
            app:backgroundTint="@color/surface_muted"
            app:icon="@drawable/ic_videocam_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/on_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEndCall"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="20dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/call_24px"
            app:iconSize="30dp"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            android:text=""
            app:backgroundTint="@color/error"
            app:cornerRadius="32dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

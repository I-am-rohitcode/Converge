<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_call_screen"
    tools:context=".VoiceCallActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/arrow_back_24px"
        app:navigationIconTint="@color/on_primary"
        app:title="@string/voice_call"
        app:titleTextColor="@color/on_primary" />

    <TextView
        android:id="@+id/peerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
        android:textColor="@color/on_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        tools:text="Aarav Patel" />

    <TextView
        android:id="@+id/callStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/call_status_calling"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        android:textColor="@color/white_70"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/peerName" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/avatarCard"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="36dp"
        app:cardBackgroundColor="@color/primary_variant"
        app:cardCornerRadius="80dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/callStatus"
        app:strokeColor="@color/white_70"
        app:strokeWidth="2dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:padding="36dp"
            android:src="@drawable/call_24px"
            app:tint="@color/on_primary" />
    </com.google.android.material.card.MaterialCardView>

    <Chronometer
        android:id="@+id/callTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:format="%s"
        android:textColor="@color/on_primary"
        android:textSize="22sp"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/avatarCard" />

    <LinearLayout
        android:id="@+id/controlsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSpeaker"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:contentDescription="@string/call_speaker"
            app:backgroundTint="@color/surface_muted"
            app:icon="@drawable/call_24px"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="28dp"
            app:iconTint="@color/on_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMute"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="28dp"
            android:contentDescription="@string/call_mute"
            app:backgroundTint="@color/surface_muted"
            app:icon="@android:drawable/ic_btn_speak_now"

            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="28dp"
            app:iconTint="@color/on_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEndCall"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="20dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/call_24px"
            app:iconSize="30dp"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            android:text=""
            app:backgroundTint="@color/error"
            app:cornerRadius="32dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

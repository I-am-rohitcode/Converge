<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="RedIndicator">
        <item name="android:color">@color/primary</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.SmallComponent</item>
    </style>

    <style name="TextAppearance.Converge.Display" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.Converge.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.Converge.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    <style name="TextAppearance.Converge.Label" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.Converge.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipMinHeight">40dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.LabelLarge</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="chipStartPadding">14dp</item>
        <item name="chipEndPadding">14dp</item>
        <item name="chipBackgroundColor">@color/chip_filter_background</item>
        <item name="android:textColor">@color/chip_filter_text</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <style name="Widget.Converge.TextInput.Message" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/chat_message_input_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">22dp</item>
        <item name="boxCornerRadiusTopEnd">22dp</item>
        <item name="boxCornerRadiusBottomStart">22dp</item>
        <item name="boxCornerRadiusBottomEnd">22dp</item>
        <item name="boxBackgroundColor">@color/card_background</item>
        <item name="hintEnabled">false</item>
    </style>
    <style name="IconButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">32dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>
</resources>
